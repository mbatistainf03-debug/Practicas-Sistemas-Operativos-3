Practica 1: compartir archivos entre linux utilizando NFS 

# Actualizar repositorios e instalar el servidor NFS
sudo apt update
sudo apt install nfs-kernel-server -y

# Crear el directorio a compartir
sudo mkdir -p /OS3

# Generar 100 archivos de prueba llamados Adrian [1..100].txt
sudo bash -c 'for i in {1..100}; do touch /OS3/Adrian$i.txt; done'

# Configurar permisos (dueño nobody para compatibilidad y lectura/escritura total)
sudo chown nobody:nogroup /OS3
sudo chmod 777 /OS3

# Configurar el archivo de exportación
# Añadimos la regla para permitir el acceso a la red local
echo "/OS3 192.168.0.0/24(rw,sync,no_subtree_check)" | sudo tee -a /etc/exports

# Abrir el firewall para permitir tráfico NFS (Vital si usas UFW)
sudo ufw allow from 192.168.0.0/24 to any port nfs

# Aplicar cambios y reiniciar el servicio
sudo exportfs -ra
sudo systemctl restart nfs-kernel-server

# Actualizar repositorios e instalar herramientas de cliente NFS
sudo apt update
sudo apt install nfs-common -y

# Crear el punto de montaje (donde veremos los archivos del servidor)
sudo mkdir -p /mnt/nfs_os3

# Montaje manual para pruebas iniciales
sudo mount 192.168.0.150:/OS3 /mnt/nfs_os3

# Verificar que los archivos están presentes
ls -l /mnt/nfs_os3 | wc -l

# Editar el archivo fstab
sudo nano /etc/fstab

# Agregar la siguiente línea al final del archivo:
# Origen: 192.168.0.150:/OS3
# Punto de montaje: /mnt/nfs_os3
# Opciones: defaults (estándar), _netdev (espera a que la red suba)
192.168.0.150:/OS3  /mnt/nfs_os3  nfs  defaults,_netdev  0  0

# Probar la configuración de fstab sin reiniciar
sudo umount /mnt/nfs_os3
sudo mount -a

# Verificar de nuevo
df -h | grep OS3

