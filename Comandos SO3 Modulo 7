Practica 3: Creacion de controlador de Dominio con cliente Windows

# 1. Configuración de Identidad y Red
# ----------------------------------------------------------
# Establecer el nombre completo del host (FQDN)
sudo hostnamectl set-hostname DebianItla20230119.so3.inet

# Configurar resolución local en /etc/hosts
# Debe apuntar la IP 192.168.0.150 al FQDN y al hostname corto
sudo bash -c 'cat <<EOF > /etc/hosts
127.0.0.1       localhost
192.168.0.150   DebianItla20230119.so3.inet DebianItla20230119
EOF'

# 2. Limpieza de Servicios Previos
# ----------------------------------------------------------
# Detener servicios de Samba estándar para evitar conflictos con el modo AD DC
sudo systemctl stop smbd nmbd winbind
sudo systemctl disable smbd nmbd winbind

# 3. Instalación de Dependencias
# ----------------------------------------------------------
sudo apt update
sudo apt install samba krb5-config smbclient -y

# 4. Aprovisionamiento del Dominio
# ----------------------------------------------------------
# Respaldar configuración original
sudo mv /etc/samba/smb.conf /etc/samba/smb.conf.bak

# Crear el dominio de forma interactiva
# Realm: SO3.INET | Domain: SO3 | Role: dc | DNS: SAMBA_INTERNAL
sudo samba-tool domain provision --use-rfc2307 --interactive

# 5. Configuración de DNS del Sistema (Importante para AD)
# ----------------------------------------------------------
sudo bash -c 'cat <<EOF > /etc/resolv.conf
domain so3.inet
search so3.inet
nameserver 127.0.0.1
EOF'

# 6. Gestión de Usuarios
# ----------------------------------------------------------
# Crear usuario solicitado con política de complejidad (Mayúscula + Números)
sudo samba-tool user create lanegracubana Itla1234567

# 7. Activación del Controlador de Dominio
# ----------------------------------------------------------
# Desenmascarar y activar el servicio unificado de AD DC
sudo systemctl unmask samba-ad-dc
sudo systemctl enable --now samba-ad-dc

# 8. Verificación
# ----------------------------------------------------------
# Listar usuarios para confirmar la creación de 'lanegracubana'
sudo samba-tool user list
