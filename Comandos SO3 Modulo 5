Practica 2: Instalacion y configuracion del Cluster
# Cambiar nombre del host
sudo hostnamectl set-hostname DebianItla20230119

# Configurar IPs estáticas
sudo nano /etc/network/interfaces
auto ens33
iface ens33 inet static
    address 192.168.0.150
    netmask 255.255.255.0
    gateway 192.168.0.1

auto ens37
iface ens37 inet static
    address 192.168.11.134
    netmask 255.255.255.0


# Cambiar nombre del host
sudo hostnamectl set-hostname nodo2

# Configurar IPs estáticas
sudo nano /etc/network/interfaces

auto ens33
iface ens33 inet static
    address 192.168.0.151
    netmask 255.255.255.0

auto ens37
iface ens37 inet static
    address 192.168.11.132
    netmask 255.255.255.0

# En ambos nodos (/etc/hosts):
192.168.11.134  DebianItla20230119
192.168.11.132  nodo2

# instalacion de componentes en ambos nodos
sudo apt update && sudo apt install pacemaker corosync crmsh openssh-server -y



# Generar llave de autenticación
sudo corosync-keygen

# Enviar llave al Nodo 2
sudo scp /etc/corosync/authkey melvin@nodo2:/home/melvin/


# nodo 2 

# Corosync exige permisos estrictos (solo lectura para root)
sudo mv /home/melvin/authkey /etc/corosync/authkey
sudo chown root:root /etc/corosync/authkey
sudo chmod 400 /etc/corosync/authkey

# configuracion de rsync en ambos nodos

totem {
    version: 2
    cluster_name: cluster_itla
    transport: udpu
}

nodelist {
    node {
        ring0_addr: 192.168.11.134
        nodeid: 1
        name: DebianItla20230119
    }
    node {
        ring0_addr: 192.168.11.132
        nodeid: 2
        name: nodo2
    }
}

quorum {
    provider: corosync_votequorum
}

logging {
    to_syslog: yes
}

# configurar ip flotantes
# reiniciar servicios
sudo systemctl restart corosync pacemaker

# 1. Desactivar STONITH (Fencing) para entorno de laboratorio
sudo crm configure property stonith-enabled=false

# 2. Ignorar política de quórum (permite operar con un solo nodo)
sudo crm configure property no-quorum-policy=ignore

# 3. Crear el recurso de la IP Flotante
sudo crm configure primitive IP_VIRTUAL ocf:heartbeat:IPaddr2 \
   params ip="192.168.0.200" cidr_netmask="24" nic="ens33" \
   op monitor interval="10s"
