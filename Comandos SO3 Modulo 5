Practica 3: Cluster de Alta Disponibilidad HTTP (1Pts)

# Actualizar repositorios e instalar Apache
sudo apt update && sudo apt install apache2 -y

# Configurar página de identificación
echo "<h1>Bienvenido al Servidor PRINCIPAL - Melvin (20230119)</h1>" | sudo tee /var/www/html/index.html

# Actualizar repositorios e instalar Apache
sudo apt update && sudo apt install apache2 -y

# Configurar página de identificación
echo "<h1>Bienvenido al Servidor SECUNDARIO - Melvin (20230119)</h1>" | sudo tee /var/www/html/index.html

#instalar en ambos
sudo apt install keepalived -y

#configurar en el principal
sudo nano /etc/keepalived/keepalived.conf

vrrp_instance VI_1 {
    state MASTER
    interface ens33           # Interfaz de red
    virtual_router_id 51
    priority 101              # Prioridad más alta para el principal
    advert_int 1
    authentication {
        auth_type PASS
        auth_pass itla2023
    }
    virtual_ipaddress {
        192.168.0.200         # Dirección IP Flotante (VIP)
    }
}


# en el secundario usando el mismo comando sudo nano /etc/keepalived/keepalived.conf

vrrp_instance VI_1 {
    state BACKUP
    interface ens33
    virtual_router_id 51
    priority 100              # Prioridad más baja
    advert_int 1
    authentication {
        auth_type PASS
        auth_pass itla2023
    }
    virtual_ipaddress {
        192.168.0.200
    }
}

# en ambos reininiciaremos los servicios y lo encenderemos de nuevo
sudo systemctl restart keepalived
sudo systemctl enable keepalived

# para acceder probar nos iremos a 
http://192.168.0.200
