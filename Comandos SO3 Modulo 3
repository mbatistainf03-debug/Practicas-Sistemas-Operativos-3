# Crear script de backup
nano backup.sh

# Contenido de backup.sh
#!/bin/bash
FECHA=$(date +"%d-%m-%Y:%H:%M")
USUARIO=$(whoami)
tar -czvf /home/$USUARIO/backup_$FECHA.tar.gz /home/$USUARIO

# Dar permisos y ejecutar
chmod +x backup.sh
./backup.sh

# Crear script para información de red
nano red_info.sh

# Contenido de red_info.sh
#!/bin/bash
echo "Ingrese el nombre del archivo:"
read NOMBRE
RUTA="/home/$(whoami)/Desktop/$NOMBRE.txt"
ifconfig > $RUTA
echo "Archivo guardado en $RUTA"

# Dar permisos y ejecutar
chmod +x red_info.sh
./red_info.sh






