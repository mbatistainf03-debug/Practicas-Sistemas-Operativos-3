Práctica 2: Gestión de Cortafuegos en Debian (iptables & UFW)

# Actualizar el índice de paquetes e instalar servidores
sudo apt update
sudo apt install apache2 vsftpd openssh-server -y

# Habilitar e iniciar servicios (Asegura el arranque tras reinicio)
sudo systemctl enable --now apache2 vsftpd ssh

ss -tuln | grep -E '21|22|80'

# -A: Añade regla, -p: Protocolo, --dport: Puerto destino, -j: Acción (DROP)
sudo iptables -A INPUT -p tcp --dport 80 -j DROP
sudo iptables -A INPUT -p tcp --dport 21 -j DROP
sudo iptables -A INPUT -p tcp --dport 22 -j DROP

#mostrar reglas

sudo iptables -L -n -v

# -F: Flush (Vaciar todas las reglas)
sudo iptables -F

#instalacion y activacion
sudo apt install ufw -y
sudo ufw enable

#bloqueo de trafico 

sudo ufw deny 80/tcp
sudo ufw deny 21/tcp
sudo ufw deny 22/tcp

#mostrar estado de firewall

sudo ufw status verbose

#habilitar trafico
sudo ufw allow 80/tcp
sudo ufw allow 21/tcp
sudo ufw allow 22/tcp
