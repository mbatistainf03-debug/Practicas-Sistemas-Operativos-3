Práctica 1 - Cifrado con GPG2 en Debian

# Actualizar repositorios e instalar GPG2 y Haveged
# haveged ayuda a generar entropía para la creación de llaves
sudo apt update && sudo apt install gnupg2 haveged -y

# Definir la terminal actual para GPG
export GPG_TTY=$(tty)

# Forzar el modo loopback para el pinentry (evita ventanas emergentes)
mkdir -p ~/.gnupg
echo "pinentry-mode loopback" >> ~/.gnupg/gpg.conf

# Reiniciar el agente para aplicar cambios
gpgconf --kill gpg-agent

gpg --full-generate-key

# Crear directorio y archivo
mkdir ~/practica_cifrado && cd ~/practica_cifrado
echo "Información secreta del ITLA" > secreto.txt

# Cifrar el archivo usando la llave pública del receptor ("Melvin")
# -e: encrypt | -r: recipient
gpg -e -r "Melvin Batista" secreto.txt

cat secreto.txt.gpg

# Descifrar y mostrar en consola
gpg -d secreto.txt.gpg

