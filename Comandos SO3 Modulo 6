practica 3Instalación de Snort 3 desde el Código Fuente (Debian Trixie)

#. Instalación de Dependencias del Sistema
sudo apt update && sudo apt upgrade -y
sudo apt install -y build-essential libpcap-dev libnet1-dev zlib1g-dev \
luajit hwloc libdumbnet-dev bison flex liblzma-dev openssl libssl-dev pkg-config \
libhwloc-dev cmake cpputest libsqlite3-dev uuid-dev libcmocka-dev \
libnetfilter-queue-dev libmnl-dev autotools-dev libluajit-5.1-dev libunwind-dev \
git libpcre2-dev libtool autoconf

#Instalación de LibDAQ
mkdir ~/snort-source-files && cd ~/snort-source-files
git clone https://github.com/snort3/libdaq.git
cd libdaq
./bootstrap
./configure
make
sudo make install
sudo ldconfig

#Compilación e Instalación de Snort 3

cd ~/snort-source-files
git clone https://github.com/snort3/snort3.git
cd snort3
./configure_cmake.sh --prefix=/usr/local/snort
cd build
make -j$(nproc)
sudo make install

#Configuración de Rutas y Enlaces Simbólicos

# Agregar al PATH del usuario
echo 'export PATH=$PATH:/usr/local/snort/bin' >> ~/.bashrc
source ~/.bashrc

# Crear enlace simbólico para acceso global (SUDO)
sudo ln -s /usr/local/snort/bin/snort /usr/bin/snort

#Configuración de Reglas (Práctica 3)
sudo mkdir -p /usr/local/snort/etc/rules
sudo nano /usr/local/snort/etc/rules/local.rules

# Detección para Práctica 3 - Melvin Batista (20230119)
alert icmp any any -> any any (msg:"[20230119] Alerta: PING detectado"; sid:1000001; rev:1;)
alert tcp any any -> any 21 (msg:"[20230119] Alerta: Acceso FTP (Port 21)"; sid:1000002; rev:1;)
alert tcp any any -> any 22 (msg:"[20230119] Alerta: Acceso SSH (Port 22)"; sid:1000003; rev:1;)
alert tcp any any -> any 80 (msg:"[20230119] Alerta: Trafico HTTP (Port 80)"; sid:1000004; rev:1;)

# Iniciar Snort 3
sudo snort -c /usr/local/snort/etc/snort/snort.lua -R /usr/local/snort/etc/rules/local.rules -i ens33 -A alert_fast
